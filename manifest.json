{
  "manifest_version": 3,
  "name": "OpenAI Codex OAuth Helper",
  "version": "1.1.0",
  "description": "后端主导的 OpenAI Codex OAuth 骨架：浏览器插件负责授权，Node 后端负责换 token。",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://auth.openai.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
